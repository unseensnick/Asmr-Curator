{
  "name": "Full Stack Dev (Ubuntu)",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "remoteUser": "devuser",
  "containerEnv": {
    "DISPLAY": "",
    "WAYLAND_DISPLAY": "",
    "DB_PATH": "/workspaces/asmr-filename-gen/data/dictionary.db",
    "PYTHONPATH": "/workspaces/asmr-filename-gen",
    "UV_LINK_MODE": "copy",
    "VIRTUAL_ENV": "/home/devuser/.venv"
  },
  "forwardPorts": [
    8000
  ],
  "postStartCommand": "/home/devuser/.local/bin/uv pip install --python /home/devuser/.venv/bin/python -r /workspaces/asmr-filename-gen/backend/requirements.txt -q",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "charliermarsh.ruff",
        "KevinRose.vsc-python-indent",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "formulahendry.auto-close-tag",
        "formulahendry.auto-rename-tag",
        "sidthesloth.html5-boilerplate",
        "ecmel.vscode-html-css",
        "Zignd.html-css-class-completion",
        "xabikos.JavaScriptSnippets",
        "msjsdiag.vscode-react-native",
        "bradlc.vscode-tailwindcss",
        "Zarifprogrammer.tailwind-snippets",
        "ms-vscode.live-server",
        "kevinkyang.auto-comment-blocks",
        "formulahendry.code-runner",
        "mikestead.dotenv",
        "oderwat.indent-rainbow",
        "christian-kohler.path-intellisense",
        "Anthropic.claude-code",
        "shd101wyy.markdown-preview-enhanced",
        "zhucy.project-tree",
        "oliverdantzer.file-structure-tree"
      ],
      "settings": {
        "terminal.integrated.fontFamily": "FiraCode Nerd Font",
        "editor.fontFamily": "FiraCode Nerd Font, 'Courier New', monospace",
        "editor.fontLigatures": true,
        "editor.fontSize": 14,
        "python.defaultInterpreterPath": "/home/devuser/.venv/bin/python"
      }
    }
  }
}