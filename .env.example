# Copy to `.env` (gitignored) and edit. LIBRARY_PATH + DOWNLOAD_PATH are
# both required (backend errors at startup if either is unset or equal).

# Host-side path to your audio library — bind-mounted into the container.
LIBRARY_PATH=/path/to/your/audio/library
# Ingest staging — patreon-dl, Drive scrape, and external-audio downloads
# land here. Must be a DIFFERENT host directory from LIBRARY_PATH (the
# backend errors on startup if they're the same path).
DOWNLOAD_PATH=/path/to/asmr-downloads

# Optional: override only if Ollama runs on a different host, or you want
# a different vision model. Defaults shown.
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen2.5vl:7b

# Advanced Drive-scrape tuning (DRIVE_SCRAPE_CONCURRENCY,
# DRIVE_BROWSER_IDLE_TIMEOUT_S, DRIVE_DOWNLOAD_TIMEOUT_S) and rare overrides
# (DB_PATH, PATREON_DL_BIN) are documented in the README under
# "Configuration". Defaults work for ~all users.
