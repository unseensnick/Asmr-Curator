{
  "manifest_version": 3,
  "name": "ASMR Workbench Companion",
  "version": "1.0.0",
  "description": "Auto-syncs your Patreon session cookie to the local ASMR Workbench backend and captures audio URLs from third-party hosts (Google Drive) embedded in Patreon posts.",
  "permissions": [
    "cookies",
    "webRequest",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://*.patreon.com/*",
    "https://*.google.com/*",
    "*://*.drive.google.com/*",
    "*://*.googleusercontent.com/*",
    "*://*.googlevideo.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "background.js",
    "scripts": [
      "lib/url-clean.js",
      "lib/post-id.js",
      "lib/storage.js",
      "background.js"
    ]
  },
  "content_scripts": [
    {
      "matches": ["https://*.patreon.com/*"],
      "js": ["lib/url-clean.js", "lib/post-id.js", "content_script.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "ASMR Workbench Companion",
    "default_popup": "popup.html"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "asmr-workbench-companion@unseensnick.local",
      "strict_min_version": "121.0"
    }
  }
}
