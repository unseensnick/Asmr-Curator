{
  "manifest_version": 3,
  "name": "ASMR Curator Companion",
  "version": "1.0.0",
  "description": "Syncs your Patreon and Google session cookies to the local ASMR Curator backend so patreon-dl and the Drive scrape can authenticate.",
  "permissions": [
    "cookies",
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "https://*.patreon.com/*",
    "https://*.google.com/*",
    "https://api.github.com/*",
    "http://*/*",
    "https://*/*"
  ],
  "icons": {
    "16": "icons/icon.svg",
    "32": "icons/icon.svg",
    "48": "icons/icon.svg",
    "128": "icons/icon.svg"
  },
  "background": {
    "service_worker": "background.js",
    "scripts": [
      "lib/storage.js",
      "background.js"
    ]
  },
  "content_scripts": [
    {
      "matches": ["https://*.patreon.com/*"],
      "js": ["content_script.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "ASMR Curator Companion",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon.svg",
      "32": "icons/icon.svg"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "asmr-curator-companion@unseensnick.local",
      "strict_min_version": "121.0"
    }
  }
}
